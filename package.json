{
  "name": "mordern-referrral",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "start": "serve -s dist -l $PORT",
    "generate:notifactions:types": "npx swagger-typescript-api generate --path https://nrs-notifications-production.up.railway.app/swagger/doc.json --output src/types --name notifications.generated.ts",
    "generate:organizations:types": "npx swagger-typescript-api generate --path https://nrs-organizations-production.up.railway.app/swagger/doc.json --output src/types --name organizations.generated.ts",
    "generate:referral:types": "npx swagger-typescript-api generate --path https://nrs-referrals-production.up.railway.app/swagger/doc.json --output src/types --name referrals.generated.ts",
    "generate:auth:types": "npx swagger-typescript-api generate --path https://nrs-authentication-production.up.railway.app/swagger/doc.json --output src/types --name auth.generated.ts"
  },
  "dependencies": {
    "@aws-amplify/ui-react": "^6.15.2",
    "@fontsource-variable/geist": "^5.2.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-query": "^5.91.0",
    "@tanstack/react-table": "^8.21.3",
    "@untitledui/icons-react": "^0.3.0",
    "aws-amplify": "^6.16.3",
    "axios": "^1.13.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.8.0",
    "oidc-client-ts": "^3.5.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.72.1",
    "react-oidc-context": "^3.3.1",
    "react-router-dom": "^7.13.1",
    "recharts": "^3.8.1",
    "serve": "^14.2.6",
    "shadcn": "^4.2.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
